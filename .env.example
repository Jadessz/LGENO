# Google Places API (New) — server-side only
GOOGLE_PLACES_API_KEY=

# Supabase — create a project at https://supabase.com
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Protect scheduled cron endpoint on Vercel (required for cron)
CRON_SECRET=

# Optional: require this key on POST/PATCH/DELETE API routes (set same value in Vite for dev)
APP_API_KEY=
VITE_APP_API_KEY=

# Local dev API server port (optional)
API_PORT=3001
